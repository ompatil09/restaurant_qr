# Supabase Configuration
# Get these values from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Example:
# VITE_SUPABASE_URL=https://xxxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Netlify Functions only. Never prefix these private values with VITE_ or
# commit real secrets. Generate APP_SESSION_SECRET with: openssl rand -hex 32
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_in_netlify_only
APP_SESSION_SECRET=replace_with_at_least_32_random_characters
STRIPE_SECRET_KEY=replace_with_a_rotated_test_or_live_secret
STRIPE_WEBHOOK_SECRET=whsec_replace_from_your_stripe_endpoint
